{
  "openapi": "3.0.0",
  "info": {
    "title": "Avid RMS Master Tracker",
    "description": "Update or read rows in the Avid RMS Master Tracker stored in Azure Table Storage.",
    "version": "1.3.0"
  },
  "servers": [
    {
      "url": "https://avid-agent-func-dyh4ahbwf5cvdha0.swedencentral-01.azurewebsites.net/api"
    }
  ],
  "paths": {
    "/update-rms": {
      "post": {
        "operationId": "updateRmsTracker",
        "summary": "Update or add a row in the RMS Master Tracker",
        "description": "Populate the master tracker in Azure Table Storage. If the RMS number already exists, it merges/updates that row. If not, it adds a new row.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["rms_number"],
                "properties": {
                  "rms_number": {
                    "type": "string",
                    "description": "The RMS document reference number (e.g., 'RMS-0023')"
                  },
                  "revision": {
                    "type": "string",
                    "description": "Revision number (e.g., '17.0')"
                  },
                  "part_number": {
                    "type": "string",
                    "description": "Internal part number (e.g., 'PN 0724')"
                  },
                  "pn_sub_code": {
                    "type": "string",
                    "description": "Part number sub-code for specific variant (e.g., '0724-1L')"
                  },
                  "material_name": {
                    "type": "string",
                    "description": "Full material name"
                  },
                  "material_class": {
                    "type": "string",
                    "description": "Material classification"
                  },
                  "description": {
                    "type": "string",
                    "description": "Physical description from Section 1.0"
                  },
                  "intended_use": {
                    "type": "string",
                    "description": "What the material is used for from Section 2.0"
                  },
                  "approved_vendors": {
                    "type": "string",
                    "description": "Approved vendors/distributors, semicolon-separated"
                  },
                  "catalog_numbers": {
                    "type": "string",
                    "description": "Vendor catalog numbers, semicolon-separated"
                  },
                  "fill_volume": {
                    "type": "string",
                    "description": "Container fill volume"
                  },
                  "container_closure": {
                    "type": "string",
                    "description": "Container type"
                  },
                  "storage_conditions": {
                    "type": "string",
                    "description": "Required storage temperature range from Section 5.0"
                  },
                  "expiration_retest": {
                    "type": "string",
                    "description": "Expiration and retest rules from Section 4.0"
                  },
                  "sampling_instructions": {
                    "type": "string",
                    "description": "Sampling procedure from Section 7.1"
                  },
                  "release_tests": {
                    "type": "string",
                    "description": "Release tests from Section 7.2.1"
                  },
                  "qualification_tests": {
                    "type": "string",
                    "description": "Qualification tests from Section 7.2.2"
                  },
                  "coa_requirements": {
                    "type": "string",
                    "description": "Certificate of Analysis requirements from Section 8.0"
                  },
                  "sop_references": {
                    "type": "string",
                    "description": "Referenced SOPs and safety documents from Section 6.0"
                  },
                  "marking_packaging": {
                    "type": "string",
                    "description": "Labeling and packaging requirements from Section 3.0"
                  },
                  "status": {
                    "type": "string",
                    "description": "Current status of this entry"
                  },
                  "notes": {
                    "type": "string",
                    "description": "Optional notes"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Result of the operation",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "action": { "type": "string" },
                    "rms_number": { "type": "string" },
                    "message": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/get-rms": {
      "get": {
        "operationId": "getRmsRow",
        "summary": "Look up an RMS number in the tracker",
        "description": "Check whether a specification has already been populated in the tracker and get its current data.",
        "parameters": [
          {
            "name": "rms_number",
            "in": "query",
            "required": true,
            "schema": { "type": "string" },
            "description": "The RMS document reference number to look up (e.g., 'RMS-0023')"
          }
        ],
        "responses": {
          "200": {
            "description": "Lookup result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "found": { "type": "boolean" },
                    "rms_number": { "type": "string" },
                    "data": { "type": "object" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/list-rms-sources": {
      "get": {
        "operationId": "listRmsSources",
        "summary": "List all RMS source .docx files in blob storage",
        "description": "Enumerates all .docx files in the RMS source blob container. Use this to discover which RMS specifications exist as source documents.",
        "responses": {
          "200": {
            "description": "List of source files",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer", "description": "Number of .docx files found" },
                    "files": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "Sorted list of blob names (e.g., 'RMS-0023.docx')"
                    },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/list-rms": {
      "get": {
        "operationId": "listRms",
        "summary": "List all RMS entries in the tracker",
        "description": "Return every RMS row currently stored in Azure Table Storage. Optionally filter by status.",
        "parameters": [
          {
            "name": "status",
            "in": "query",
            "required": false,
            "schema": { "type": "string" },
            "description": "Optional status filter (e.g., 'Populated', 'Imported'). Case-insensitive."
          }
        ],
        "responses": {
          "200": {
            "description": "All tracker entries",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "total": { "type": "integer" },
                    "entries": {
                      "type": "array",
                      "items": { "type": "object" },
                      "description": "Array of RMS row objects with all populated fields"
                    },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/bulk-update-rms": {
      "post": {
        "operationId": "bulkUpdateRmsTracker",
        "summary": "Batch update or add multiple RMS rows",
        "description": "Accept an array of RMS entries and upsert them into Table Storage in one call. Maximum 200 entries per batch.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["entries"],
                "properties": {
                  "entries": {
                    "type": "array",
                    "description": "Array of RMS entry objects. Each follows the same schema as the /update-rms body.",
                    "items": {
                      "type": "object",
                      "required": ["rms_number"],
                      "properties": {
                        "rms_number": { "type": "string", "description": "The RMS document reference number (e.g., 'RMS-0023')" },
                        "revision": { "type": "string", "description": "Revision number (e.g., '17.0')" },
                        "part_number": { "type": "string", "description": "Internal part number (e.g., 'PN 0724')" },
                        "pn_sub_code": { "type": "string", "description": "Part number sub-code for specific variant (e.g., '0724-1L')" },
                        "material_name": { "type": "string", "description": "Full material name" },
                        "material_class": { "type": "string", "description": "Material classification" },
                        "description": { "type": "string", "description": "Physical description from Section 1.0" },
                        "intended_use": { "type": "string", "description": "What the material is used for from Section 2.0" },
                        "approved_vendors": { "type": "string", "description": "Approved vendors/distributors, semicolon-separated" },
                        "catalog_numbers": { "type": "string", "description": "Vendor catalog numbers, semicolon-separated" },
                        "fill_volume": { "type": "string", "description": "Container fill volume" },
                        "container_closure": { "type": "string", "description": "Container type" },
                        "storage_conditions": { "type": "string", "description": "Required storage temperature range from Section 5.0" },
                        "expiration_retest": { "type": "string", "description": "Expiration and retest rules from Section 4.0" },
                        "sampling_instructions": { "type": "string", "description": "Sampling procedure from Section 7.1" },
                        "release_tests": { "type": "string", "description": "Release tests from Section 7.2.1, formatted as 'Test | Method | Spec' per line" },
                        "qualification_tests": { "type": "string", "description": "Qualification tests from Section 7.2.2, formatted as 'Test | Method | Spec' per line" },
                        "coa_requirements": { "type": "string", "description": "Certificate of Analysis requirements from Section 8.0" },
                        "sop_references": { "type": "string", "description": "Referenced SOPs and safety documents from Section 6.0" },
                        "marking_packaging": { "type": "string", "description": "Labeling and packaging requirements from Section 3.0" },
                        "status": { "type": "string", "description": "Current status of this entry" },
                        "notes": { "type": "string", "description": "Optional notes" }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Batch result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "added": { "type": "integer" },
                    "updated": { "type": "integer" },
                    "errors": { "type": "array", "items": { "type": "object" } },
                    "message": { "type": "string" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/tracker-status": {
      "get": {
        "operationId": "getTrackerStatus",
        "summary": "Get tracker progress summary",
        "description": "Dashboard endpoint returning counts of source documents, populated entries, pending items, status breakdown, and last update timestamp.",
        "responses": {
          "200": {
            "description": "Tracker status summary",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "source_docs": { "type": "integer", "description": "Total .docx files in blob storage (null if unavailable)" },
                    "populated": { "type": "integer", "description": "Number of entries in the tracker" },
                    "pending": { "type": "integer", "description": "Source docs not yet in tracker (null if source unavailable)" },
                    "status_breakdown": { "type": "object", "description": "Count per status value, e.g. {\"Populated\": 3, \"Imported\": 2}" },
                    "last_updated": { "type": "string", "description": "Most recent last_updated date across all entries" },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/export-excel-link": {
      "get": {
        "operationId": "getExportExcelLink",
        "summary": "Get a download link for the Excel tracker",
        "description": "Returns a JSON object with a clickable URL to download the RMS Master Tracker as an Excel file. Use this when the user asks to download or export the tracker.",
        "responses": {
          "200": {
            "description": "Download link",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "download_url": { "type": "string", "description": "Direct URL to download the .xlsx file" },
                    "filename": { "type": "string", "description": "Suggested filename for the download" },
                    "message": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/diff-rms": {
      "get": {
        "operationId": "diffRms",
        "summary": "Compare source files vs tracker entries",
        "description": "Cross-references blob storage source .docx files against Table Storage entries. Returns which RMS numbers are missing from the tracker, which are in the tracker but have no source file, and which are fully matched.",
        "responses": {
          "200": {
            "description": "Diff result",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "missing_from_tracker": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "RMS numbers that exist as source docs but are not in the tracker"
                    },
                    "in_tracker_no_source": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "RMS numbers in the tracker that have no matching source doc"
                    },
                    "fully_populated": {
                      "type": "array",
                      "items": { "type": "string" },
                      "description": "RMS numbers present in both source and tracker"
                    },
                    "summary": {
                      "type": "object",
                      "properties": {
                        "total_source": { "type": "integer" },
                        "total_in_tracker": { "type": "integer" },
                        "missing": { "type": "integer" },
                        "no_source": { "type": "integer" },
                        "matched": { "type": "integer" }
                      }
                    },
                    "error": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
